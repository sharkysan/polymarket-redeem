# Copy to ".env" in the repository root (same folder as this file) and fill in values.
# Never commit .env — it is listed in .gitignore.

# Wallet that signs relayer transactions (hex private key, with or without 0x).
# Also used (with the relayer SDK) to derive your Polymarket Safe address for on-chain balance checks.
# Alias supported by the script: POLY_PRIVATE_KEY
POLYMARKET_PRIVATE_KEY=

# Proxy or Safe address that holds positions (used for Data API lookups and relayer).
POLYMARKET_WALLET_ADDRESS=

# Polymarket Builder API credentials (from your builder profile)
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# 1 = proxy (default), 0 or 2 = Safe — must match how your account is set up on Polymarket
POLYMARKET_SIGNATURE_TYPE=1

# --- Optional tuning ---
# Max redemptions per relayer execute (default 1; try 5–12 if stable)
# POLY_REDEEM_BATCH=1

# Seconds to sleep when relayer returns HTTP 429 / 1015
# POLY_REDEEM_RELAYER_WAIT=60

# Retries for Data API transient errors
# POLY_REDEEM_DATA_RETRIES=3

# Polygon JSON-RPC URL (used to skip redeemable API rows that are already redeemed on-chain)
# POLY_RPC_URL=https://polygon-bor.publicnode.com

# Set to 0 to only trust the Data API (no on-chain filter)
# POLY_REDEEM_VERIFY_ONCHAIN=1

# On-chain filter: dual (default) | balance | simulate
# POLY_REDEEM_ONCHAIN_MODE=dual

# If 1: when dual mode sees 0 on one contract and RPC fails for the other, drop the row (riskier)
# POLY_REDEEM_AGGRESSIVE_ZERO=0

# If 1, deploy the Polymarket Gnosis Safe via relayer before redeem (if not already deployed)
# POLY_REDEEM_AUTO_DEPLOY_SAFE=0
