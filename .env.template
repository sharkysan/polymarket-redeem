# =============================================================================
# Repository root — copy this file to ".env" here (next to README.md).
# Used by: redeem/poly_redeem.py, redeem_loop.py, redeem/auto_claim_proxy.py,
#           redeem/auto-claim-proxy.js (all read this file only).
# Run scripts from the repository top level (e.g. `python redeem/...`).
# Never commit .env (see .gitignore).

# --- Execution mode (poly_redeem.py) ---
# direct = sign redeemPositions with your EOA (needs POL/MATIC on that address)
# relayer = Polymarket builder + Gnosis Safe (gasless; needs builder creds below)
# POLY_REDEEM_MODE=direct

# Primary EOA key (hex, with or without 0x). Direct redeems + default Safe signer for relayer.
# Aliases: POLY_PRIVATE_KEY, or for PROXY loop only PRIVATE_KEY=
POLYMARKET_PRIVATE_KEY=

# Optional — relayer only: if set, Safe txs use this key instead of POLYMARKET_PRIVATE_KEY.
# Must be the key for the same Polymarket login as POLYMARKET_WALLET_ADDRESS.
# Alias: POLY_RELAYER_PRIVATE_KEY
# POLYMARKET_RELAYER_PRIVATE_KEY=

# Data API "user" and custody address. For relayer Safe path this must match
# derive(EOA from the signing key). Wrong key => no tokens on signing Safe, redeems no-op.
# Alias for proxy scripts in redeem/: see USER_ADDRESS in redeem/.env.template
POLYMARKET_WALLET_ADDRESS=

# Polymarket Builder HMAC (Settings > Builder > API keys). Secret/passphrase shown once.
# https://docs.polymarket.com/builders/api-keys — do not put a leading "." on the API key value.
# Omit all three if using Relayer API key pair below instead.
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# Alternative relayer auth (Settings > API Keys): RELAYER_API_KEY + address.
# Used when Builder vars above are all empty unless POLY_REDEEM_USE_RELAYER_API_KEY forces it.
# POLYMARKET_RELAYER_API_KEY=
# POLYMARKET_RELAYER_API_KEY_ADDRESS=
# Aliases: RELAYER_API_KEY, RELAYER_API_KEY_ADDRESS

# signature_type for builder client (1 = proxy wallet style default in docs; match your account)
POLYMARKET_SIGNATURE_TYPE=1

# --- Optional tuning (poly_redeem.py) ---
# POLY_REDEEM_BATCH=1
# POLY_REDEEM_RELAYER_WAIT=60
# POLY_REDEEM_RELAYER_MAX_WAIT=172800
# POLY_REDEEM_RELAYER_RESET_MARGIN=30
# POLY_REDEEM_RELAYER_MAX_IN_PROCESS_SLEEP=1800
# POLY_REDEEM_RELAYER_NO_SLEEP=1
# POLY_REDEEM_RELAYER_MAX_POLLS=180
# POLY_REDEEM_RELAYER_POLL_MS=2000
# POLY_REDEEM_DATA_RETRIES=3
# POLY_REDEEM_IGNORE_LOST=1

# Polygon RPC (on-chain verify, direct sends). Aliases work in proxy script as POLYGON_RPC_URL.
# POLY_RPC_URL=https://polygon-bor.publicnode.com

# POLY_REDEEM_VERIFY_ONCHAIN=1
# POLY_REDEEM_ONCHAIN_MODE=dual
# POLY_REDEEM_AGGRESSIVE_ZERO=0
# POLY_REDEEM_AUTO_DEPLOY_SAFE=0

# --- redeem_loop.py ---
# POLY_REDEEM_LOOP_SECONDS=600
# POLY_REDEEM_LOOP_RELAYER=1
# POLY_REDEEM_LOOP_EXTRA_ARGS=

# --- PROXY relayer loop (optional) — same file; optional duplicate names ---
# PRIVATE_KEY=                    # same as POLYMARKET_PRIVATE_KEY if you prefer
# USER_ADDRESS=                   # same as POLYMARKET_WALLET_ADDRESS
# BUILDER_API_KEY=              # same as POLYMARKET_BUILDER_API_KEY (Node script)
# BUILDER_SECRET=
# BUILDER_PASS_PHRASE=
# RELAYER_URL=  CHAIN_ID=  POLL_MS=

# --- Dry-run ---
# python redeem/poly_redeem.py --dry-run
# python redeem/auto_claim_proxy.py --dry-run
